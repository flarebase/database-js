{
  "name": "@flarebasejs/database-js",
  "version": "0.0.2",
  "description": "Flarebase JavaScript Client for Flarebase Database",
  "author": "Flarebase",
  "homepage": "https://github.com/flarebase/database-js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flarebase/database-js.git"
  },
  "bugs": "https://github.com/flarebase/database-js/issues",
  "keywords": [
    "javascript",
    "typescript",
    "flarebase",
    "database",
    "sdk"
  ],
  "exports": {
    ".": {
      "types": "./dist/cjs/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/cjs/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "pnpm run clean && pnpm run build:cjs && pnpm run build:esm",
    "build:cjs": "tsc -p tsconfig.commonjs.json",
    "build:esm": "tsc -p tsconfig.esm.json",
    "docs": "typedoc src/index.ts --out docs/v1",
    "test": "vitest",
    "lint": "eslint ./src",
    "lint:fix": "eslint ./src --fix",
    "type-check": "tsc --noEmit",
    "prepublish": "pnpm run build && pnpm run test && pnpm run type-check"
  },
  "devDependencies": {
    "@nyxb/eslint-config": "^3.1.0",
    "@vitest/coverage-v8": "3.1.2",
    "eslint": "^9.27.0",
    "typedoc": "^0.28.4",
    "vite": "^6.3.4",
    "vitest": "^3.1.2"
  }
}
